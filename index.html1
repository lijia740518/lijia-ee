<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>重庆福彩路段推荐数据 - 2026年5月</title>
    <meta name="description" content="重庆福彩城南区域渠道建设路段推荐数据展示">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap');
        
        * {
            font-family: 'Noto Sans SC', sans-serif;
        }
        
        .gradient-hero {
            background: linear-gradient(135deg, #dc2626 0%, #ef4444 50%, #f97316 100%);
        }
        
        .text-gradient {
            background: linear-gradient(135deg, #dc2626, #f97316);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .shadow-elegant {
            box-shadow: 0 10px 40px -10px rgba(220, 38, 38, 0.15);
        }
        
        .shadow-card {
            box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.1);
        }
        
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px -10px rgba(220, 38, 38, 0.2);
        }
        
        .animate-fade-in {
            animation: fadeIn 0.6s ease-out;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .smooth-scroll {
            scroll-behavior: smooth;
        }
        
        .table-row-hover:hover {
            background-color: #fef2f2;
        }
        
        .filter-active {
            background-color: #dc2626;
            color: white;
        }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #dc2626;
            border-radius: 4px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #b91c1c;
        }
    </style>
</head>
<body class="smooth-scroll bg-gray-50">
    <!-- Hero Section -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden gradient-hero">
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full blur-3xl animate-pulse"></div>
            <div class="absolute bottom-20 right-10 w-96 h-96 bg-white rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
        </div>

        <div class="container mx-auto px-4 py-16 relative z-10">
            <div class="max-w-5xl mx-auto text-center">
                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-6 animate-fade-in">
                    <i class="fas fa-map-marker-alt text-white text-sm"></i>
                    <span class="text-white text-sm font-medium">城南区域 · 2026年5月</span>
                </div>

                <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight animate-fade-in">
                    重庆福彩路段推荐数据
                </h1>

                <p class="text-xl md:text-2xl text-white/90 mb-8 max-w-3xl mx-auto leading-relaxed animate-fade-in">
                    城南区域渠道建设路段推荐表，涵盖巴南、大渡口、九龙坡、南岸、渝中五个区县
                </p>

                <!-- Statistics Cards -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto animate-fade-in">
                    <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20">
                        <div class="text-3xl font-bold text-white mb-1" id="totalRecords">88</div>
                        <div class="text-white/80 text-sm">总记录数</div>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20">
                        <div class="text-3xl font-bold text-white mb-1">5</div>
                        <div class="text-white/80 text-sm">覆盖区县</div>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20">
                        <div class="text-3xl font-bold text-white mb-1" id="totalStreets">0</div>
                        <div class="text-white/80 text-sm">涉及街道</div>
                    </div>
                    <div class="bg-white/10 backdrop-blur-sm rounded-xl p-4 border border-white/20">
                        <div class="text-3xl font-bold text-white mb-1">福店</div>
                        <div class="text-white/80 text-sm">推荐类型</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Filter Section -->
    <section class="py-8 bg-white border-b border-gray-200 sticky top-0 z-40 shadow-sm">
        <div class="container mx-auto px-4">
            <div class="max-w-7xl mx-auto">
                <div class="flex flex-wrap gap-3 items-center">
                    <div class="flex items-center gap-2 mr-4">
                        <i class="fas fa-filter text-red-600"></i>
                        <span class="font-semibold text-gray-900">筛选：</span>
                    </div>
                    
                    <!-- District Filter -->
                    <button onclick="filterByDistrict('all')" id="filter-all" class="filter-btn filter-active px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        全部
                    </button>
                    <button onclick="filterByDistrict('巴南区')" class="filter-btn px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        巴南区
                    </button>
                    <button onclick="filterByDistrict('大渡口区')" class="filter-btn px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        大渡口区
                    </button>
                    <button onclick="filterByDistrict('九龙坡区')" class="filter-btn px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        九龙坡区
                    </button>
                    <button onclick="filterByDistrict('南岸区')" class="filter-btn px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        南岸区
                    </button>
                    <button onclick="filterByDistrict('渝中区')" class="filter-btn px-4 py-2 rounded-lg border border-gray-300 transition-all duration-300 hover:shadow-md">
                        渝中区
                    </button>
                    
                    <!-- Search Box -->
                    <div class="ml-auto relative">
                        <input type="text" id="searchInput" placeholder="搜索街道、地段、经理..." 
                               class="pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent w-64"
                               oninput="searchData()">
                        <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Data Table Section -->
    <section class="py-12 bg-gray-50">
        <div class="container mx-auto px-4">
            <div class="max-w-7xl mx-auto">
                <!-- Results Info -->
                <div class="mb-6 flex justify-between items-center">
                    <h2 class="text-2xl font-bold text-gray-900">
                        <span class="text-gradient">路段推荐列表</span>
                    </h2>
                    <div class="text-gray-600">
                        显示 <span id="showingCount" class="font-semibold text-red-600">88</span> 条记录
                    </div>
                </div>

                <!-- Table Container -->
                <div class="bg-white rounded-2xl shadow-elegant overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gradient-to-r from-red-600 to-orange-500 text-white">
                                <tr>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">序号</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">区县</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">片区</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">街道</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">区域经理</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">联系电话</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">路段类型</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold min-w-[200px]">具体可建地段</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">租金预估</th>
                                    <th class="px-4 py-4 text-left text-sm font-semibold">推荐类型</th>
                                </tr>
                            </thead>
                            <tbody id="dataTableBody" class="divide-y divide-gray-200">
                                <!-- Data will be inserted here by JavaScript -->
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Empty State -->
                    <div id="emptyState" class="hidden py-16 text-center">
                        <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
                        <p class="text-gray-500 text-lg">未找到匹配的记录</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-white py-8">
        <div class="container mx-auto px-4">
            <div class="max-w-7xl mx-auto text-center">
