            {"序号":86,"区县":"渝中区","所属片区":"B2片区","街道":"解放碑街道","区域经理":"易飞","联系电话":"13883666565","路段类型":"商圈路段","具体可建地段":"解放碑国泰广场","路段租金预估":"40000元/月","可建站推荐类型":"福店"},
            {"序号":87,"区县":"渝中区","所属片区":"A1片区","街道":"七星岗街道","区域经理":"段四海","联系电话":"13635459966","路段类型":"大中型社区","具体可建地段":"通远门小区门口","路段租金预估":"9000元/月","可建站推荐类型":"福店"},
            {"序号":88,"区县":"渝中区","所属片区":"A2片区","街道":"两路口","区域经理":"易飞","联系电话":"13883666565","路段类型":"商业综合体","具体可建地段":"重百大楼入口","路段租金预估":"28000元/月","可建站推荐类型":"福店"}
        ];

        let filteredData = [...excelData];
        let currentFilter = 'all';

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            renderTable(excelData);
            updateStatistics();
            document.getElementById('year').textContent = new Date().getFullYear();
        });

        // Render table
        function renderTable(data) {
            const tbody = document.getElementById('dataTableBody');
            const emptyState = document.getElementById('emptyState');
            
            if (data.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                document.getElementById('showingCount').textContent = '0';
                return;
            }
            
            emptyState.classList.add('hidden');
            document.getElementById('showingCount').textContent = data.length;
            
            tbody.innerHTML = data.map((row, index) => `
                <tr class="table-row-hover transition-colors duration-200 ${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'}">
                    <td class="px-4 py-3 text-sm text-gray-900">${row.序号}</td>
                    <td class="px-4 py-3 text-sm text-gray-900 font-medium">${row.区县}</td>
                    <td class="px-4 py-3 text-sm text-gray-600">${row.所属片区}</td>
                    <td class="px-4 py-3 text-sm text-gray-900">${row.街道}</td>
                    <td class="px-4 py-3 text-sm text-gray-900">${row.区域经理}</td>
                    <td class="px-4 py-3 text-sm text-gray-600">
                        <a href="tel:${row.联系电话}" class="text-blue-600 hover:text-blue-800">
                            ${row.联系电话}
                        </a>
                    </td>
                    <td class="px-4 py-3 text-sm">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            ${row.路段类型}
                        </span>
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-900 max-w-xs truncate" title="${row.具体可建地段}">
                        ${row.具体可建地段}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-900 font-semibold">${row.路段租金预估}</td>
                    <td class="px-4 py-3 text-sm">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            ${row.可建站推荐类型}
                        </span>
                    </td>
                </tr>
            `).join('');
        }

        // Filter by district
        function filterByDistrict(district) {
            currentFilter = district;
            
            // Update button styles
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('filter-active');
            });
            
            if (district === 'all') {
                document.getElementById('filter-all').classList.add('filter-active');
                filteredData = [...excelData];
            } else {
                event.target.classList.add('filter-active');
                filteredData = excelData.filter(row => row.区县 === district);
            }
            
            // Clear search input
            document.getElementById('searchInput').value = '';
            
            renderTable(filteredData);
        }

        // Search data
        function searchData() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            
            if (!searchTerm) {
                filteredData = currentFilter === 'all' 
                    ? [...excelData] 
                    : excelData.filter(row => row.区县 === currentFilter);
            } else {
                filteredData = excelData.filter(row => {
                    const matchesFilter = currentFilter === 'all' || row.区县 === currentFilter;
                    const matchesSearch = 
                        row.街道.toLowerCase().includes(searchTerm) ||
                        row.具体可建地段.toLowerCase().includes(searchTerm) ||
                        row.区域经理.toLowerCase().includes(searchTerm) ||
                        row.路段类型.toLowerCase().includes(searchTerm) ||
                        row.所属片区.toLowerCase().includes(searchTerm);
                    return matchesFilter && matchesSearch;
                });
            }
            
            renderTable(filteredData);
        }

        // Update statistics
        function updateStatistics() {
            const uniqueStreets = new Set(excelData.map(row => row.街道));
            document.getElementById('totalStreets').textContent = uniqueStreets.size;
        }
    </script>
</body>
</html>
